{
	"name": "webcam-circle",
	"productName": "WebcamCircle",
	"version": "0.2.1",
	"description": "Show your webcam view in a circle above all other windows",
	"main": "index.js",
	"license": "MIT",
	"repository": "cainhill/WebcamCircle",
	"author": {
		"name": "Cain Hill",
		"email": "cainhill@gmail.com",
		"url": "https://cainhill.com.au"
	},
	"scripts": {
		"postinstall": "electron-builder install-app-deps",
		"lint": "xo",
		"test": "npm run lint",
		"start": "electron .",
		"pack": "electron-builder --dir",
		"dist": "electron-builder --windows",
		"dist:mac": "electron-builder --mac --arm64 --x64",
		"release:mac": "./scripts/release-mac.sh",
		"release": "np"
	},
	"comment_1": "https://github.com/electron-userland/electron-builder/issues/4157#issuecomment-596419610",
	"devDependencies": {
		"electron": "^30.5.1",
		"electron-builder": "^24.13.3",
		"np": "^5.0.3",
		"xo": "^0.25.3"
	},
	"xo": {
		"envs": [
			"node",
			"browser"
		]
	},
	"np": {
		"publish": false,
		"releaseDraft": false
	},
	"build": {
		"appId": "com.cainhill.WebcamCircle",
		"win": {
			"target": "portable",
			"icon": "build/icon.ico"
		},
		"mac": {
			"target": [
				{
					"target": "dmg",
					"arch": [
						"arm64",
						"x64"
					]
				}
			],
			"artifactName": "${productName}-${version}-${arch}.${ext}",
			"icon": "build/icon.icns",
			"category": "public.app-category.video",
			"identity": null,
			"extendInfo": {
				"NSCameraUsageDescription": "WebcamCircle uses your camera to display the video feed as a floating circle."
			}
		}
	}
}
